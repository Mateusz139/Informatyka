#include <stdio.h>
#include <stdlib.h>
#include <time.h>
main()
{

    int i, aSize;
    int * randomNums;
    time_t t;
    int biggest, smallest;
    biggest = 0;
    smallest = 0;

        srand(time(&t));
        printf("\n Podaj dolny zakres \n ");
        scanf("%d", &smallest);
        printf("Podaj gorny zakres \n ");
        scanf("%d", &biggest);
        printf("Ile liczb losowych chcesz zapisac w tablicy? ");
        scanf(" %d", &aSize);
        randomNums = (int *) malloc(aSize * sizeof(int));

        for (i = 0; i < aSize; i++)
        {
            randomNums[i] = smallest + rand() % (biggest-smallest+1)  ;
        }
        printf("Oto twoje liczby");
        for (i = 0; i < aSize; i++) {
            printf(" %d,", randomNums[i]);
        }
    while (aSize != 0) {
        printf("\n Podaj dolny zakres \n ");
        scanf("%d", &smallest);
        printf("Podaj gorny zakres \n ");
        scanf("%d", &biggest);
        printf("Ile liczb losowych chcesz zapisac w tablicy? ");
        scanf(" %d", &aSize);
        randomNums = (int *) realloc(randomNums, aSize * sizeof(int));

        for (i = 0; i <aSize; i++)
        {
            randomNums[i] = smallest + rand() % (biggest-smallest+1);
      
        }
        printf("Oto twoje liczby");
        for (i = 0; i < aSize; i++) {
            printf(" %d,", randomNums[i]);
        }
    }
    free(randomNums);
    return(0);
}
