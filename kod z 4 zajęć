    } 
    return aktualneMiejsce; 
} 
//TASOWANIE (Algorytm Fishera-Yatesa) 
void tasujTablice(char tablica[], int rozmiar) { 
    for (int i = rozmiar - 1; i > 0; i--) { 
        int wylosowaneMiejsce = rand() % (i + 1); 
        char temp = tablica[i]; 
        tablica[i] = tablica[wylosowaneMiejsce]; 
        tablica[wylosowaneMiejsce] = temp; 
    } 
} 
 
