    #include <cstring> 
     
   void usage(char *programName) { 
        printf("Usage: %s number1 operation number\n", programName); 
        printf("Available operations:\n"); 
        printf("\t+\n"); 
        printf("\t-\n"); 
        printf("\tx\n"); 
        printf("\t/\n"); 
        printf("\n"); 
    } 
     
   int main(int argc, char* argv[]) { 
     
       int number1 = 0; 
        int number2 = 0; 
        int result = 0; 
     
       if (argc == 4) { 
            number1 = atoi(argv[1]); 
            number2 = atoi(argv[3]); 
     
           if (!strcmp("+", argv[2])) { 
                result = number1 + number2; 
                printf("%d + %d = %d\n", number1, number2, result); 
                return 0; 
            } 
            if (!strcmp("-", argv[2])) { 
                result = number1 - number2; 
                printf("%d - %d = %d\n", number1, number2, result); 
                return 0; 
            } 
            if (!strcmp("x", argv[2])) { 
                result = number1 * number2; 
                printf("%d x %d = %d\n", number1, number2, result); 
                return 0; 
            } 
            if (!strcmp("/", argv[2])) { 
                result = number1 / number2; 
                printf("%d / %d = %d\n", number1, number2, result); 
                return 0; 
            } 
        } 
     
       usage(argv[0]); 
     
       return 0; 
    } 
 
 
